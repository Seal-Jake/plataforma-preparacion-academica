DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="8h"
PORT=3000
NODE_ENV=development
CLIENT_ORIGIN="http://localhost:4200"

# --- Producción (Render) ---
# DATABASE_URL debe ser la cadena de conexión de Postgres (Neon/Supabase), y se usa
# junto a server/prisma/schema.production.prisma (no schema.prisma, que es solo para
# desarrollo local con SQLite). NODE_ENV=production activa la cookie de sesión "Secure"
# (requiere HTTPS, que Render provee automáticamente) y sirve el build de Angular desde
# este mismo servidor, por lo que CLIENT_ORIGIN ya no es estrictamente necesario.
