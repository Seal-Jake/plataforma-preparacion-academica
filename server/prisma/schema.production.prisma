// Copia de schema.prisma usada SOLO para el despliegue en producción (Postgres).
// El desarrollo local sigue usando schema.prisma (SQLite) sin tocar este archivo.
// Los modelos deben mantenerse idénticos entre ambos; solo cambia el datasource.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Estos campos son plain Strings constreñidos por zod en la capa de aplicación
// (ver src/lib/enums.ts), igual que en schema.prisma.
// Role: 'docente' | 'estudiante'
// Seccion: 'matematica' | 'economia_aplicada'
// Nivel: 'basico' | 'estandar' | 'deco' | 'admision' | 'retos'
// TipoPregunta: 'operaciones' | 'enunciado' | 'problema_lectura' | 'interpretacion_grafica' | 'proposicion_vf'
// AcademicSession.tipoFijo: 'participacion_clase' | 'practica' | 'participacion_activa' | 'examen_unidad' | 'proyecto_unidad' | 'examen_final_curso' | 'proyecto_final_curso'
// TipoFijoCarpeta: 'concepto_teoria' | 'mecanica_ejemplos' | 'actividad_practica' | 'aplicacion_economia'
// ThemePreference: 'dark' | 'light'

model User {
  id                   String   @id @default(cuid())
  name                 String
  email                String   @unique
  passwordHash         String
  role                 String
  avatarUrl            String?
  avatarData           Bytes?
  avatarMimeType       String?
  themePreference      String   @default("dark")
  notificationsEnabled Boolean  @default(true)
  createdAt            DateTime @default(now())

  enrollments   Enrollment[]
  attempts      Attempt[]
  sessionStates StudentSessionState[]
  entregas      Entrega[]             @relation("EntregaEstudiante")
  progresos     ProgressMark[]
}

model Course {
  id             String  @id @default(cuid())
  name           String
  orderIndex     Int
  infoEvaluacion String?

  units       Unit[]
  enrollments Enrollment[]
  sessions    AcademicSession[]
}

model Unit {
  id         String @id @default(cuid())
  courseId   String
  name       String
  orderIndex Int

  course   Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  topics   Topic[]
  sessions AcademicSession[]

  @@index([courseId])
}

model Topic {
  id         String  @id @default(cuid())
  unitId     String
  name       String
  orderIndex Int
  subtemas   String?

  unit      Unit              @relation(fields: [unitId], references: [id], onDelete: Cascade)
  questions Question[]
  sessions  AcademicSession[]
  folders   Folder[]

  @@index([unitId])
}

// Las 4 carpetas con tipoFijo no nulo se crean automáticamente al crear el
// tema y no pueden renombrarse ni borrarse. Todo lo demás (tipoFijo = null)
// lo crea el docente libremente, como en un Explorador de Archivos.
model Folder {
  id         String   @id @default(cuid())
  topicId    String
  parentId   String?
  nombre     String
  tipoFijo   String?
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())

  topic     Topic          @relation(fields: [topicId], references: [id], onDelete: Cascade)
  parent    Folder?        @relation("FolderChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[]       @relation("FolderChildren")
  archivos  FileItem[]
  progresos ProgressMark[]

  @@index([topicId])
  @@index([parentId])
}

model FileItem {
  id             String   @id @default(cuid())
  folderId       String
  nombre         String
  contenidoTexto String?
  data           Bytes?
  mimeType       String?
  sizeBytes      Int?
  subidoPor      String
  createdAt      DateTime @default(now())

  folder Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([folderId])
}

model Question {
  id              String   @id @default(cuid())
  topicId         String
  section         String
  nivel           String
  tipo            String
  modoRespuesta   String   @default("opciones") // "opciones" (alternativas, autocorregible) | "abierta" (texto/archivo, calificación manual)
  enunciado       String
  archivoData     Bytes? // imagen/archivo adjunto al enunciado (ej. foto de un problema con notación matemática)
  archivoMimeType String?
  explicacion     String?
  esModelo        Boolean  @default(false)
  createdAt       DateTime @default(now())

  topic    Topic            @relation(fields: [topicId], references: [id], onDelete: Cascade)
  opciones QuestionOption[]
  attempts Attempt[]

  @@index([topicId])
}

model QuestionOption {
  id         String  @id @default(cuid())
  questionId String
  texto      String
  esCorrecta Boolean @default(false)
  orderIndex Int     @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model Enrollment {
  id        String   @id @default(cuid())
  studentId String
  courseId  String
  createdAt DateTime @default(now())

  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
}

// Rúbrica fija de la plataforma (ver TIPOS_SESION_FIJOS en lib/enums.ts):
// cada tema recibe automáticamente sus 3 sesiones fijas (Participación en
// Clase, Práctica, Participación Activa), cada unidad las suyas (Examen y
// Proyecto de Unidad), y cada curso las suyas (Examen Final y Proyecto
// Final). tipoFijo identifica cuál es, y exactamente uno de
// courseId/unitId/topicId corresponde al nivel de esa sesión (topicId
// también implica su unitId para poder consultar por unidad directamente).
model AcademicSession {
  id                String    @id @default(cuid())
  courseId          String?
  unitId            String?
  topicId           String?
  tipoFijo          String
  title             String
  questionIds       String // JSON array of question ids, canonical order ("[]" si es de tipo evidencia)
  dueDate           DateTime?
  timeLimitMinutes  Int?
  abiertoParaTodos  Boolean   @default(false)
  requiereEvidencia Boolean   @default(false)
  pesoAciertos      Float     @default(40)
  pesoEvidencia     Float     @default(60)
  createdAt         DateTime  @default(now())

  course        Course?               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  unit          Unit?                 @relation(fields: [unitId], references: [id], onDelete: Cascade)
  topic         Topic?                @relation(fields: [topicId], references: [id], onDelete: Cascade)
  attempts      Attempt[]
  studentStates StudentSessionState[]
  entregas      Entrega[]

  @@index([courseId])
  @@index([unitId])
  @@index([topicId])
  @@index([tipoFijo])
}

model StudentSessionState {
  id            String    @id @default(cuid())
  sessionId     String
  studentId     String
  questionOrder String // JSON array of question ids, order shown to this student
  startedAt     DateTime  @default(now())
  deadlineAt    DateTime?
  submittedAt   DateTime?

  session AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student User            @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
}

model Attempt {
  id                String   @id @default(cuid())
  sessionId         String
  studentId         String
  questionId        String
  selectedOptionIds String // JSON array de ids de QuestionOption elegidos ("[]" si es de respuesta abierta)
  shownOptionOrder  String // JSON array de ids de QuestionOption, orden mostrado (auditoría)
  respuestaTexto    String? // respuesta de texto libre, solo preguntas de modoRespuesta="abierta"
  archivoData       Bytes? // archivo adjunto, solo preguntas de modoRespuesta="abierta"
  archivoMimeType   String?
  puntaje           Float? // 0..1, parcial. Null = todavía sin calificar (preguntas abiertas antes de que el docente las revise)
  correct           Boolean? // atajo: puntaje === 1. Null mientras no se haya calificado
  answeredAt        DateTime @default(now())

  session  AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student  User            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  question Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId, questionId])
  @@index([sessionId])
  @@index([studentId])
}

// Reemplaza Investigacion: unifica Investigación, Participación Activa
// (foto), Tareas extra, Retos, y la evidencia del examen — cualquier
// entrega de texto/archivo que el docente califica manualmente.
model Entrega {
  id              String    @id @default(cuid())
  sessionId       String
  studentId       String
  contenidoTexto  String?
  archivoData     Bytes?
  archivoMimeType String?
  nota            Float?
  feedback        String?
  entregadoAt     DateTime?

  session AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student User            @relation("EntregaEstudiante", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
}

model ProgressMark {
  id        String   @id @default(cuid())
  studentId String
  folderId  String
  marcadoAt DateTime @default(now())

  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  folder  Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@unique([studentId, folderId])
}
